{
  "$schema": "https://schemas.analitiq.ai/pipeline/latest.json",
  "pipeline_id": "30303030-3030-4030-8030-303030303030",
  "display_name": "Stripe to warehouse + lake",
  "description": "Replicates Stripe events to PostgreSQL and S3 daily at 02:00 Berlin time.",
  "status": "draft",
  "connections": {
    "source": "31313131-3131-4131-8131-313131313131",
    "destinations": [
      "05050505-0505-4505-8505-050505050505",
      "02020202-0202-4202-8202-020202020202"
    ]
  },
  "streams": [
    "32323232-3232-4232-8232-323232323232"
  ],
  "schedule": {
    "type": "cron",
    "timezone": "Europe/Berlin",
    "cron_expression": "cron(0 2 * * ? *)"
  },
  "engine": {
    "vcpu": 2,
    "memory": 16384
  },
  "runtime": {
    "buffer_size": 10000,
    "batching": {
      "batch_size": 1000,
      "max_concurrent_batches": 5
    },
    "logging": {
      "log_level": "INFO",
      "metrics_enabled": true
    },
    "error_handling": {
      "strategy": "dlq",
      "max_retries": 3,
      "retry_delay_seconds": 10
    }
  },
  "tags": ["billing"]
}
