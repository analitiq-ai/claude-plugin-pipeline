{
  "$schema": "https://schemas.analitiq.ai/stream/latest.json",
  "pipeline_id": "wise_to_postgresql",
  "source": {
    "endpoint_ref": {
      "scope": "connection",
      "connection_id": "mysql_source",
      "endpoint_id": "public_orders"
    },
    "filters": [
      {"field": "name", "operator": "starts_with", "value": "foo"},
      {"field": "deleted_at", "operator": "is_null", "value": null},
      {"field": "status", "operator": "eq"}
    ],
    "replication": {"method": "full_refresh"}
  },
  "destinations": [
    {
      "endpoint_ref": {
        "scope": "connection",
        "connection_id": "postgresql",
        "endpoint_id": "warehouse_orders"
      },
      "write": {"mode": "insert"}
    }
  ]
}
