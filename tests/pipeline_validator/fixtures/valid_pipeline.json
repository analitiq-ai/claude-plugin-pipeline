{
  "$schema": "https://schemas.analitiq.ai/pipeline/latest.json",
  "pipeline_id": "11111111-1111-4111-8111-111111111111",
  "display_name": "Wise to PostgreSQL",
  "description": "Replicates Wise transfers to PostgreSQL.",
  "status": "draft",
  "connections": {
    "source": "22222222-2222-4222-8222-222222222222",
    "destinations": [
      "33333333-3333-4333-8333-333333333333"
    ]
  },
  "streams": [
    "44444444-4444-4444-8444-444444444444"
  ],
  "schedule": {
    "type": "manual",
    "timezone": "UTC"
  },
  "engine": {
    "vcpu": 1,
    "memory": 8192
  },
  "runtime": {
    "buffer_size": 5000,
    "batching": {
      "batch_size": 200,
      "max_concurrent_batches": 3
    },
    "logging": {
      "log_level": "INFO",
      "metrics_enabled": true
    },
    "error_handling": {
      "strategy": "dlq",
      "max_retries": 3,
      "retry_delay_seconds": 5
    }
  },
  "tags": ["finance", "warehouse"]
}
